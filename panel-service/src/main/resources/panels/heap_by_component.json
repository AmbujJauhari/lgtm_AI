{
  "panelId": "heap_by_component",
  "description": "JVM heap usage over time for all affected components",
  "datasource": "IBMimir",
  "requiredVariables": ["components", "appcode", "timeFrom", "timeTo"],
  "categories": ["NPE", "OOM", "THREAD_DEADLOCK"],
  "panelJson": {
    "type": "timeseries",
    "title": "Heap Usage — $components",
    "datasource": {"type": "prometheus", "uid": "IBMimir"},
    "fieldConfig": {
      "defaults": {
        "unit": "bytes",
        "custom": {"lineWidth": 1, "fillOpacity": 10}
      }
    },
    "options": {"tooltip": {"mode": "multi"}},
    "targets": [
      {
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "IBMimir"},
        "expr": "jvm_memory_used_bytes{appcode=\"$appcode\", area=\"heap\", service=~\"$components\"}",
        "legendFormat": "{{service}} heap"
      }
    ]
  }
}
