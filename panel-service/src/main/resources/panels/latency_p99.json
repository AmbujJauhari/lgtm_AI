{
  "panelId": "latency_p99",
  "description": "P99 request latency for affected components",
  "datasource": "IBMimir",
  "requiredVariables": ["components", "appcode", "timeFrom", "timeTo"],
  "categories": ["TIMEOUT", "CONNECTION_REFUSED"],
  "panelJson": {
    "type": "timeseries",
    "title": "P99 Latency — $components",
    "datasource": {"type": "prometheus", "uid": "IBMimir"},
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "custom": {"lineWidth": 2, "fillOpacity": 5}
      }
    },
    "options": {"tooltip": {"mode": "multi"}},
    "targets": [
      {
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "IBMimir"},
        "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{appcode=\"$appcode\", service=~\"$components\"}[5m])) by (le, service))",
        "legendFormat": "{{service}} p99"
      }
    ]
  }
}
