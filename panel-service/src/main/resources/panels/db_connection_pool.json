{
  "panelId": "db_connection_pool",
  "description": "Database connection pool utilisation for the originating service",
  "datasource": "IBMimir",
  "requiredVariables": ["service", "appcode", "timeFrom", "timeTo"],
  "categories": ["DB_ERROR"],
  "panelJson": {
    "type": "timeseries",
    "title": "DB Connection Pool — $service",
    "datasource": {"type": "prometheus", "uid": "IBMimir"},
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {"lineWidth": 1, "fillOpacity": 15}
      }
    },
    "options": {"tooltip": {"mode": "multi"}},
    "targets": [
      {
        "refId": "A",
        "datasource": {"type": "prometheus", "uid": "IBMimir"},
        "expr": "hikaricp_connections_active{appcode=\"$appcode\", service=\"$service\"}",
        "legendFormat": "{{service}} active"
      },
      {
        "refId": "B",
        "datasource": {"type": "prometheus", "uid": "IBMimir"},
        "expr": "hikaricp_connections_pending{appcode=\"$appcode\", service=\"$service\"}",
        "legendFormat": "{{service}} pending"
      },
      {
        "refId": "C",
        "datasource": {"type": "prometheus", "uid": "IBMimir"},
        "expr": "hikaricp_connections_max{appcode=\"$appcode\", service=\"$service\"}",
        "legendFormat": "{{service}} max"
      }
    ]
  }
}
